<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PostgreSQL EXPLAIN — Visual Guide</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:       #0b0f1a;
  --card:     #111827;
  --card2:    #1a2235;
  --border:   #1f2d45;
  --border2:  #2a3f5f;
  --text:     #e2e8f0;
  --muted:    #4a6080;
  --mono:     'Space Mono', monospace;
  --sans:     'DM Sans', sans-serif;

  --seq:   #e85d3d;
  --idx:   #22c55e;
  --bmp:   #f59e0b;
  --warn:  #f97316;
  --ok:    #22c55e;
  --info:  #38bdf8;
}

* { margin:0; padding:0; box-sizing:border-box; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--sans);
  min-height: 100vh;
}

.wrap { max-width: 960px; margin: 0 auto; padding: 40px 20px 80px; }

/* header */
.top-label {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 12px;
}
h1 {
  font-family: var(--mono);
  font-size: clamp(22px, 4vw, 38px);
  font-weight: 700;
  color: var(--text);
  line-height: 1.2;
  margin-bottom: 8px;
}
h1 em { color: var(--info); font-style: normal; }
.sub {
  font-size: 14px;
  color: var(--muted);
  margin-bottom: 40px;
  line-height: 1.6;
}

/* tabs */
.tabs {
  display: flex;
  gap: 4px;
  margin-bottom: 28px;
  border-bottom: 1px solid var(--border);
  padding-bottom: 0;
}
.tab {
  font-family: var(--mono);
  font-size: 11px;
  padding: 8px 18px;
  cursor: pointer;
  color: var(--muted);
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: all 0.15s;
  white-space: nowrap;
}
.tab:hover { color: var(--text); }
.tab.active { color: var(--info); border-bottom-color: var(--info); }

.view { display: none; }
.view.active { display: block; animation: up 0.18s ease; }
@keyframes up { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }

/* section title */
.stitle {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.stitle::after { content:''; flex:1; height:1px; background:var(--border); }

/* explain block — the core component */
.explain-block {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 16px;
}
.explain-query {
  background: var(--card2);
  border-bottom: 1px solid var(--border);
  padding: 12px 16px;
  font-family: var(--mono);
  font-size: 12px;
  color: #7dd3fc;
  line-height: 1.6;
}
.explain-query .kw { color: #c084fc; }
.explain-query .str { color: #86efac; }
.explain-output {
  padding: 16px;
  font-family: var(--mono);
  font-size: 12px;
  line-height: 2;
  overflow-x: auto;
}

/* clickable explain lines */
.eline {
  display: flex;
  align-items: baseline;
  gap: 0;
  cursor: pointer;
  border-radius: 4px;
  padding: 2px 6px;
  margin: 0 -6px;
  transition: background 0.12s;
  flex-wrap: wrap;
}
.eline:hover { background: rgba(255,255,255,0.04); }
.eline.active { background: rgba(56,189,248,0.08); }

.indent-0 { padding-left: 6px; }
.indent-1 { padding-left: 28px; }
.indent-2 { padding-left: 52px; }
.indent-3 { padding-left: 76px; }

/* node type colors */
.node-seq   { color: var(--seq); font-weight: 700; }
.node-idx   { color: var(--idx); font-weight: 700; }
.node-bmp   { color: var(--bmp); font-weight: 700; }
.node-join  { color: #a78bfa; font-weight: 700; }
.node-agg   { color: #38bdf8; font-weight: 700; }
.node-sort  { color: #f472b6; font-weight: 700; }
.node-limit { color: #94a3b8; font-weight: 700; }

.cost-est { color: #64748b; font-size: 11px; }
.cost-actual { color: #94a3b8; font-size: 11px; }
.cost-bad { color: var(--warn); font-size: 11px; font-weight: 700; }
.cond { color: #e2e8f0; font-size: 11px; }
.cond-key { color: var(--muted); }
.removed { color: var(--warn); font-size: 11px; }
.removed-ok { color: var(--ok); font-size: 11px; }
.disk-bad { color: #ef4444; font-weight: 700; font-size: 11px; }
.disk-ok  { color: var(--ok); font-size: 11px; }

/* annotation badge */
.badge {
  display: inline-block;
  font-size: 9px;
  font-family: var(--mono);
  padding: 1px 7px;
  border-radius: 2px;
  margin-left: 8px;
  vertical-align: middle;
}
.badge-warn { background: rgba(249,115,22,0.15); color: var(--warn); border: 1px solid rgba(249,115,22,0.3); }
.badge-ok   { background: rgba(34,197,94,0.12);  color: var(--ok);   border: 1px solid rgba(34,197,94,0.3); }
.badge-info { background: rgba(56,189,248,0.12); color: var(--info); border: 1px solid rgba(56,189,248,0.3); }

/* detail panel */
.detail {
  background: var(--card);
  border: 1px solid var(--border2);
  border-left: 3px solid var(--info);
  border-radius: 6px;
  padding: 20px 22px;
  margin-top: 4px;
  margin-bottom: 20px;
  transition: border-left-color 0.2s;
}
.detail.empty {
  opacity: 0.35;
  border-left-color: var(--border);
}
.detail h3 {
  font-family: var(--mono);
  font-size: 13px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.detail p {
  font-size: 13px;
  color: #8b9ab5;
  line-height: 1.75;
  margin-bottom: 10px;
}
.detail p:last-child { margin-bottom: 0; }
.detail strong { color: var(--text); font-weight: 600; }
.detail code {
  font-family: var(--mono);
  font-size: 11px;
  background: rgba(56,189,248,0.08);
  color: #7dd3fc;
  padding: 1px 6px;
  border-radius: 3px;
}
.detail .fix {
  background: rgba(34,197,94,0.07);
  border: 1px solid rgba(34,197,94,0.2);
  border-radius: 4px;
  padding: 10px 12px;
  font-family: var(--mono);
  font-size: 11px;
  color: #86efac;
  line-height: 1.8;
  margin-top: 10px;
}
.tag { display:inline-block; font-size:10px; font-family:var(--mono); padding:2px 8px; border-radius:2px; border:1px solid; margin:3px 2px 0; }
.t-ok   { color:var(--ok);   border-color:rgba(34,197,94,0.3);   background:rgba(34,197,94,0.07); }
.t-warn { color:var(--warn); border-color:rgba(249,115,22,0.3);  background:rgba(249,115,22,0.07); }
.t-bad  { color:#ef4444;     border-color:rgba(239,68,68,0.3);   background:rgba(239,68,68,0.07); }
.t-info { color:var(--info); border-color:rgba(56,189,248,0.3);  background:rgba(56,189,248,0.07); }

/* scan cards */
.scan-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 14px;
  margin-bottom: 20px;
}
.scan-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.15s;
}
.scan-card:hover, .scan-card.lit {
  border-color: var(--c);
  box-shadow: 0 0 20px var(--cg);
}
.scan-card-head {
  padding: 12px 16px 8px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 10px;
}
.scan-title { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--c); }
.scan-when  { font-size: 11px; color: var(--muted); margin-left: auto; }
.scan-body  { padding: 12px 16px; font-size: 12px; color: #64748b; line-height: 1.65; }
.scan-viz {
  background: var(--card2);
  margin: 8px 0;
  border-radius: 4px;
  padding: 8px 10px;
  font-family: var(--mono);
  font-size: 10px;
  color: #475569;
  line-height: 1.8;
}
.scan-viz .hi { color: var(--c); }
.scan-viz .dim { opacity: 0.3; }

/* warning cards */
.warn-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 20px;
}
.warn-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  cursor: pointer;
  transition: all 0.15s;
}
.warn-card:hover, .warn-card.lit { border-color: var(--wc); box-shadow: 0 0 16px var(--wcg); }
.warn-num { font-family: var(--mono); font-size: 28px; font-weight: 700; color: var(--wc); margin-bottom: 4px; }
.warn-title { font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
.warn-desc { font-size: 12px; color: var(--muted); line-height: 1.6; }
.warn-snippet {
  margin-top: 10px;
  padding: 7px 10px;
  background: var(--card2);
  border-radius: 4px;
  font-family: var(--mono);
  font-size: 10px;
  color: #475569;
  line-height: 1.7;
}
.warn-snippet .bad { color: #ef4444; }
.warn-snippet .good { color: var(--ok); }

/* flow diagram */
.flow {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 20px;
  overflow-x: auto;
  padding: 4px 0;
}
.flow-step {
  flex-shrink: 0;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 12px 16px;
  text-align: center;
  cursor: pointer;
  transition: all 0.15s;
  min-width: 120px;
}
.flow-step:hover, .flow-step.lit {
  border-color: var(--fc);
  box-shadow: 0 0 16px var(--fcg);
}
.flow-icon  { font-size: 20px; margin-bottom: 4px; }
.flow-label { font-family: var(--mono); font-size: 10px; font-weight: 700; color: var(--fc); }
.flow-sub   { font-size: 10px; color: var(--muted); margin-top: 3px; }
.flow-arrow { color: var(--border2); font-size: 20px; padding: 0 6px; flex-shrink: 0; }

/* debug checklist */
.checklist { margin-bottom: 20px; }
.check-item {
  display: flex;
  gap: 14px;
  padding: 14px 16px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 6px;
  margin-bottom: 8px;
  cursor: pointer;
  transition: all 0.15s;
  align-items: flex-start;
}
.check-item:hover { border-color: var(--border2); background: var(--card2); }
.check-item.lit { border-color: var(--info); background: rgba(56,189,248,0.04); }
.check-num {
  font-family: var(--mono);
  font-size: 18px;
  font-weight: 700;
  color: var(--info);
  flex-shrink: 0;
  line-height: 1;
  margin-top: 2px;
  min-width: 28px;
}
.check-content { flex: 1; }
.check-title { font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.check-body  { font-size: 12px; color: var(--muted); line-height: 1.55; }
.check-look  {
  font-family: var(--mono);
  font-size: 10px;
  margin-top: 7px;
  padding: 5px 8px;
  background: var(--bg);
  border-radius: 3px;
  color: #475569;
  line-height: 1.7;
}
.check-look .spot { color: var(--warn); }
.check-look .fix  { color: var(--ok); }

@media (max-width: 600px) {
  .warn-grid { grid-template-columns: 1fr; }
  .flow { flex-direction: column; align-items: stretch; }
  .flow-arrow { transform: rotate(90deg); text-align: center; }
}
</style>
</head>
<body>
<div class="wrap">

  <div class="top-label">postgresql · query planning · visual guide</div>
  <h1>Understanding<br><em>EXPLAIN</em></h1>
  <p class="sub">Click anything to learn what it means. No jargon, just patterns.</p>

  <!-- TABS -->
  <div class="tabs">
    <div class="tab active" onclick="switchTab('how')">How It Works</div>
    <div class="tab" onclick="switchTab('scans')">Scan Types</div>
    <div class="tab" onclick="switchTab('read')">Reading Output</div>
    <div class="tab" onclick="switchTab('warnings')">Warning Signs</div>
    <div class="tab" onclick="switchTab('debug')">Debug Process</div>
  </div>

  <!-- ═══════ HOW IT WORKS ═══════ -->
  <div class="view active" id="view-how">

    <div class="stitle">What happens when you run a query</div>

    <div class="flow">
      <div class="flow-step" style="--fc:#c084fc;--fcg:rgba(192,132,252,0.2)" onclick="flowDetail('parse')">
        <div class="flow-icon">📝</div>
        <div class="flow-label">PARSE</div>
        <div class="flow-sub">Read the SQL text</div>
      </div>
      <div class="flow-arrow">→</div>
      <div class="flow-step" style="--fc:#38bdf8;--fcg:rgba(56,189,248,0.2)" onclick="flowDetail('analyze')">
        <div class="flow-icon">🔍</div>
        <div class="flow-label">ANALYZE</div>
        <div class="flow-sub">Check tables & types</div>
      </div>
      <div class="flow-arrow">→</div>
      <div class="flow-step" style="--fc:#f59e0b;--fcg:rgba(245,158,11,0.2)" onclick="flowDetail('plan')">
        <div class="flow-icon">🗺️</div>
        <div class="flow-label">PLAN</div>
        <div class="flow-sub">Pick the best route</div>
      </div>
      <div class="flow-arrow">→</div>
      <div class="flow-step" style="--fc:#22c55e;--fcg:rgba(34,197,94,0.2)" onclick="flowDetail('execute')">
        <div class="flow-icon">⚡</div>
        <div class="flow-label">EXECUTE</div>
        <div class="flow-sub">Actually read rows</div>
      </div>
    </div>

    <div class="detail empty" id="detail-how">
      <h3>← Click a step to understand it</h3>
      <p>Each stage has a specific job. The PLAN stage is where most interesting decisions happen.</p>
    </div>

    <div class="stitle">The two commands</div>

    <div class="explain-block">
      <div class="explain-query">
        <span class="kw">EXPLAIN</span> <span class="kw">SELECT</span> * <span class="kw">FROM</span> users <span class="kw">WHERE</span> id = <span class="str">42</span>;
        <br><span style="color:#475569;font-size:10px">-- Shows the plan only. Does NOT run the query.</span>
      </div>
      <div class="explain-output">
        <div class="eline indent-0" onclick="lineDetail('basic_node')">
          <span class="node-idx">Index Scan</span>&nbsp;
          <span style="color:#94a3b8">using users_pkey on users</span>&nbsp;
          <span class="cost-est">(cost=0.43..8.45 rows=1 width=64)</span>
          <span class="badge badge-ok">fast</span>
        </div>
        <div class="eline indent-1" onclick="lineDetail('index_cond')">
          <span class="cond-key">Index Cond:&nbsp;</span>
          <span class="cond">(id = 42)</span>
        </div>
      </div>
    </div>

    <div class="explain-block">
      <div class="explain-query">
        <span class="kw">EXPLAIN ANALYZE</span> <span class="kw">SELECT</span> * <span class="kw">FROM</span> users <span class="kw">WHERE</span> id = <span class="str">42</span>;
        <br><span style="color:#475569;font-size:10px">-- Actually runs the query. Shows estimate + reality.</span>
      </div>
      <div class="explain-output">
        <div class="eline indent-0" onclick="lineDetail('analyze_node')">
          <span class="node-idx">Index Scan</span>&nbsp;
          <span style="color:#94a3b8">using users_pkey on users</span>
        </div>
        <div class="eline indent-1" onclick="lineDetail('cost_line')">
          <span class="cost-est">(cost=0.43..8.45 rows=1 width=64)</span>&nbsp;
          <span class="badge badge-info">estimate</span>
        </div>
        <div class="eline indent-1" onclick="lineDetail('actual_line')">
          <span class="cost-actual">(actual time=0.031..0.034 rows=1 loops=1)</span>&nbsp;
          <span class="badge badge-ok">reality</span>
        </div>
        <div class="eline indent-1" onclick="lineDetail('index_cond')">
          <span class="cond-key">Index Cond:&nbsp;</span>
          <span class="cond">(id = 42)</span>
        </div>
      </div>
    </div>

    <div class="detail empty" id="detail-how2">
      <h3>← Click any line in the output above</h3>
      <p>Every piece of that output has a specific meaning.</p>
    </div>

  </div>

  <!-- ═══════ SCANS ═══════ -->
  <div class="view" id="view-scans">
    <div class="stitle">The three scan types you'll see most</div>

    <div class="scan-grid">

      <div class="scan-card" style="--c:var(--seq);--cg:rgba(232,93,61,0.2)" onclick="scanDetail('seq')">
        <div class="scan-card-head">
          <span style="font-size:20px">📚</span>
          <span class="scan-title">Seq Scan</span>
          <span class="scan-when">reads everything</span>
        </div>
        <div class="scan-body">
          Reads every single row in the table. Like reading a whole book to find one word.
          <div class="scan-viz">
            page 1 <span class="hi">████</span> → check<br>
            page 2 <span class="hi">████</span> → check<br>
            page 3 <span class="hi">████</span> → check<br>
            page 4 <span class="hi">████</span> → <span style="color:#22c55e">found!</span>
          </div>
          Not always bad — fast for small tables or when returning most rows.
        </div>
      </div>

      <div class="scan-card" style="--c:var(--idx);--cg:rgba(34,197,94,0.2)" onclick="scanDetail('idx')">
        <div class="scan-card-head">
          <span style="font-size:20px">🎯</span>
          <span class="scan-title">Index Scan</span>
          <span class="scan-when">jumps to rows</span>
        </div>
        <div class="scan-body">
          Uses the index to jump directly to matching rows. Like using a book's index page.
          <div class="scan-viz">
            index: id=42 <span class="hi">→ page 4, slot 7</span><br>
            <span class="dim">page 1 ████ (skipped)</span><br>
            <span class="dim">page 2 ████ (skipped)</span><br>
            page 4 <span class="hi">→ slot 7 → found!</span>
          </div>
          Best for selective queries returning few rows.
        </div>
      </div>

      <div class="scan-card" style="--c:var(--bmp);--cg:rgba(245,158,11,0.2)" onclick="scanDetail('bmp')">
        <div class="scan-card-head">
          <span style="font-size:20px">🗺️</span>
          <span class="scan-title">Bitmap Heap Scan</span>
          <span class="scan-when">middle ground</span>
        </div>
        <div class="scan-body">
          First marks which pages to visit, then reads them in order. Two-step approach.
          <div class="scan-viz">
            step 1: build bitmap of pages<br>
            &nbsp;&nbsp;→ <span class="hi">page 2, page 4, page 7</span><br>
            step 2: read marked pages<br>
            &nbsp;&nbsp;→ <span class="hi">found 5000 matching rows</span>
          </div>
          Best for moderate result sets — not too few, not too many.
        </div>
      </div>

    </div>

    <div class="detail empty" id="detail-scans">
      <h3>← Click a scan type to learn more</h3>
      <p>Each scan type is best in different situations.</p>
    </div>

    <div class="stitle">When does each appear?</div>

    <div class="explain-block">
      <div class="explain-output" style="padding: 12px 16px">
        <div style="font-family:var(--mono);font-size:10px;color:var(--muted);margin-bottom:10px;letter-spacing:0.1em">CLICK A ROW TO SEE WHEN THE PLANNER CHOOSES EACH SCAN</div>

        <div class="eline indent-0" onclick="whenDetail('when_seq')" style="margin-bottom:6px">
          <span class="node-seq">Seq Scan</span>
          <span style="font-size:11px;color:var(--muted);margin-left:10px">on orders — no index, or returning many rows</span>
        </div>

        <div class="eline indent-0" onclick="whenDetail('when_idx')" style="margin-bottom:6px">
          <span class="node-idx">Index Scan</span>
          <span style="font-size:11px;color:var(--muted);margin-left:10px">using idx_email — returning very few rows</span>
        </div>

        <div class="eline indent-0" onclick="whenDetail('when_bmp')" style="margin-bottom:6px">
          <span class="node-bmp">Bitmap Heap Scan</span>
          <span style="font-size:11px;color:var(--muted);margin-left:10px">on orders — returning moderate number of rows</span>
        </div>

        <div class="eline indent-1" onclick="whenDetail('when_bmp')" style="margin-bottom:6px">
          <span style="color:var(--muted)">→&nbsp;</span>
          <span class="node-bmp">Bitmap Index Scan</span>
          <span style="font-size:11px;color:var(--muted);margin-left:6px">on idx_status — building the page map</span>
        </div>

        <div class="eline indent-0" onclick="whenDetail('when_ios')">
          <span class="node-idx" style="color:#22d3ee">Index Only Scan</span>
          <span style="font-size:11px;color:var(--muted);margin-left:10px">— all needed columns are in the index</span>
          <span class="badge badge-ok">fastest</span>
        </div>
      </div>
    </div>

    <div class="detail empty" id="detail-when">
      <h3>← Click a scan type above</h3>
      <p>The planner chooses based on estimated row count and available indexes.</p>
    </div>

  </div>

  <!-- ═══════ READING OUTPUT ═══════ -->
  <div class="view" id="view-read">
    <div class="stitle">A real multi-step plan — click every line</div>

    <div class="explain-block">
