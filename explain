<script>
// ── TAB SWITCHING ──
const tabMap = { how:0, scans:1, read:2, warnings:3, debug:4 };
function switchTab(name) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('view-' + name).classList.add('active');
  document.querySelectorAll('.tab')[tabMap[name]].classList.add('active');
}

// ── DETAIL HELPER ──
function setDetail(id, color, icon, title, body) {
  const el = document.getElementById(id);
  if (!el) return;
  el.style.borderLeftColor = color;
  el.classList.remove('empty');
  el.innerHTML = `<h3><span>${icon}</span> ${title}</h3>${body}`;
  el.scrollIntoView({ behavior:'smooth', block:'nearest' });
}

// ── HOW IT WORKS ──
const flowData = {
  parse: ['#c084fc','📝','Parse — Reading Your SQL',
    `<p>PostgreSQL reads the raw SQL text and checks that it's syntactically valid. It converts the text into an internal tree structure representing the query's intent.</p>
    <p>If you have a typo like <code>SELET</code> instead of <code>SELECT</code>, the error happens here. This step is fast — just text processing.</p>`],
  analyze: ['#38bdf8','🔍','Analyze — Checking Tables & Types',
    `<p>PostgreSQL resolves your table names and column names against the system catalog. It checks that <code>users.email</code> actually exists and has the right type.</p>
    <p>Views are expanded here — if you query a view, it gets replaced by the underlying SELECT. This is also where permission checks happen.</p>`],
  plan: ['#f59e0b','🗺️','Plan — Choosing the Best Route',
    `<p><strong>This is the interesting step.</strong> The planner generates multiple ways to execute the query and estimates the cost of each. Then picks the cheapest.</p>
    <p>It uses statistics about your data (stored in <code>pg_stats</code>) to estimate how many rows each step will produce. If those statistics are stale, it picks the wrong plan.</p>
    <p><strong>This is what EXPLAIN shows you</strong> — the plan the planner chose.</p>`],
  execute: ['#22c55e','⚡','Execute — Actually Running the Plan',
    `<p>The chosen plan is handed to the executor, which reads actual data pages, applies filters, joins tables, and returns rows to you.</p>
    <p><strong>EXPLAIN ANALYZE</strong> runs this step and adds actual timing and row counts alongside the planner's estimates — so you can see where the plan was right or wrong.</p>`],
};
function flowDetail(key) {
  const [color,icon,title,body] = flowData[key];
  setDetail('detail-how', color, icon, title, body);
  document.querySelectorAll('.flow-step').forEach(e=>e.classList.remove('lit'));
  event.currentTarget.classList.add('lit');
}

// ── EXPLAIN LINES ──
const lineData = {
  basic_node: ['#22c55e','🎯','Index Scan — PostgreSQL chose the index',
    `<p>This means PostgreSQL is using the <code>users_pkey</code> (primary key) index to find the row with id=42 directly, rather than reading every row in the table.</p>
    <p>For a lookup by primary key, this is exactly what you want. It will do 3–4 page reads regardless of how big the table is.</p>
    <span class="tag t-ok">Good plan for point lookups</span>`],
  index_cond: ['#38bdf8','🔎','Index Cond — The condition applied in the index',
    `<p><strong>Index Cond</strong> is the filter applied while traversing the index itself. Only rows matching this condition have their ctid extracted — so no heap pages are read for non-matching rows.</p>
    <p>Compare this to <strong>Filter</strong> (without "Index") which is applied <em>after</em> fetching from the heap — meaning those rows were read from disk and then discarded.</p>
    <span class="tag t-ok">Index Cond = efficient</span><span class="tag t-warn">Filter = rows fetched then discarded</span>`],
  cost_line: ['#64748b','💰','cost=X..Y — The planner\'s estimate',
    `<p>These are not milliseconds — they're abstract units. <strong>1.0 = cost of reading one page sequentially.</strong></p>
    <p><strong>First number (0.43)</strong> — startup cost. Work done before the first row can be returned. High for sorts and aggregations.</p>
    <p><strong>Second number (8.45)</strong> — total cost to return all rows.</p>
    <p>Only useful for comparing two plans — bigger number = planner thinks it's more expensive.</p>`],
  actual_line: ['#94a3b8','⏱️','actual time=X..Y — What really happened',
    `<p>These <strong>are</strong> milliseconds. Shows how long this node actually took when the query ran.</p>
    <p><strong>First number</strong> — time until first row was returned.</p>
    <p><strong>Second number</strong> — time to return all rows.</p>
    <p><strong>rows=1</strong> — how many rows this node actually returned.</p>
    <p><strong>loops=1</strong> — how many times this node ran. In nested loop joins, this can be very high.</p>
    <span class="tag t-info">Always compare rows estimate vs actual rows</span>`],
  analyze_node: ['#22c55e','🌳','The node type — what operation is happening',
    `<p>The first word of each line tells you what operation is being performed at this step in the plan. Common ones:</p>
    <p><strong>Index Scan</strong> — use index, fetch heap rows<br>
    <strong>Seq Scan</strong> — read whole table<br>
    <strong>Hash Join</strong> — join using hash table<br>
    <strong>HashAggregate</strong> — GROUP BY using hash<br>
    <strong>Sort</strong> — ORDER BY<br>
    <strong>Limit</strong> — LIMIT clause</p>`],
};
function lineDetail(key) {
  const [c,i,t,b] = lineData[key];
  setDetail('detail-how2', c, i, t, b);
  document.querySelectorAll('.eline.active').forEach(e=>e.classList.remove('active'));
  event.currentTarget.classList.add('active');
}

// ── SCANS ──
const scanData = {
  seq: ['#e85d3d','📚','Seq Scan — Reading Everything',
    `<p>PostgreSQL reads every page of the table from start to finish. Every row is checked against the filter condition.</p>
    <p><strong>When it's the right choice:</strong></p>
    <p>• The table is small (a few thousand rows — just read it all)<br>
    • The query returns a large fraction of the table (say, 30%+ of rows)<br>
    • No suitable index exists</p>
    <p><strong>When it's a problem:</strong> Seq Scan on a large table with a very selective filter — you're reading millions of rows to find one.</p>
    <div class="fix">Look for: Seq Scan + high "Rows Removed by Filter"</div>`],
  idx: ['#22c55e','🎯','Index Scan — Jumping to the Right Rows',
    `<p>PostgreSQL traverses the B-Tree index to find matching entries (ctids), then fetches each heap row directly using those ctids. Random I/O — one disk seek per row.</p>
    <p><strong>When it's the right choice:</strong></p>
    <p>• Query is highly selective (returning &lt;10% of rows)<br>
    • An index exists on the filter column<br>
    • Fetching a small number of rows</p>
    <p><strong>When it becomes a problem:</strong> Returning many rows via Index Scan causes many random page reads. At some threshold (usually 5–15% of rows), sequential scan becomes faster.</p>
    <span class="tag t-ok">Best for: point lookups, highly selective filters</span>`],
  bmp: ['#f59e0b','🗺️','Bitmap Heap Scan — The Smart Middle Ground',
    `<p>A two-phase approach:<br><br>
    <strong>Phase 1 (Bitmap Index Scan):</strong> Scans the index and builds an in-memory bitmap of which pages contain matching rows. Doesn't fetch any heap rows yet.<br><br>
    <strong>Phase 2 (Bitmap Heap Scan):</strong> Reads only the flagged pages, in physical order (efficient sequential-ish I/O).</p>
    <p>This avoids the worst of random I/O while still using the index to skip irrelevant pages.</p>
    <p><strong>Recheck Cond:</strong> If the bitmap grows too large (exceeds work_mem), it becomes "lossy" — it only tracks pages, not individual rows. PostgreSQL must then recheck each row. Increase work_mem to avoid this.</p>
    <span class="tag t-info">Best for: moderate result sets — 1% to 20% of table</span>`],
};
function scanDetail(key) {
  const [c,i,t,b] = scanData[key];
  setDetail('detail-scans', c, i, t, b);
  document.querySelectorAll('.scan-card.lit').forEach(e=>e.classList.remove('lit'));
  event.currentTarget.classList.add('lit');
}

const whenData = {
  when_seq: ['#e85d3d','📚','When Planner Chooses Seq Scan',
    `<p>The planner chooses Seq Scan when it estimates the cost of a sequential read is lower than an index scan. This happens when:</p>
    <p><strong>1. No index exists</strong> — no choice but to scan.<br>
    <strong>2. High selectivity</strong> — if 80% of rows match the filter, sequential I/O beats random I/O.<br>
    <strong>3. Small table</strong> — a table with 100 rows fits in a page or two. No index needed.<br>
    <strong>4. Stale statistics</strong> — planner thinks only 50 rows match when really 50,000 do.</p>
    <div class="fix">Check: EXPLAIN ANALYZE shows rows=50 but actual rows=50000 → run ANALYZE</div>`],
  when_idx: ['#22c55e','🎯','When Planner Chooses Index Scan',
    `<p>Planner chooses Index Scan when it estimates that few rows match, making the random I/O of index traversal + heap fetch cheaper than reading all pages sequentially.</p>
    <p>The crossover point is roughly <strong>5–15% of the table</strong>. Below that → Index Scan. Above that → Seq Scan or Bitmap Heap Scan.</p>
    <p><strong>The planner can get this wrong</strong> if statistics are stale. It might use Index Scan thinking 10 rows match, when 500,000 do — causing thousands of random I/Os that are slower than a sequential scan would have been.</p>`],
